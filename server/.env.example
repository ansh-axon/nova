# Copy this file to .env and fill in your real values.
# Never commit the real .env file.

# MongoDB Atlas connection string (from cloud.mongodb.com)
# Example: mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/nova-chat?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI=

# Secret used to sign login tokens (use a long random string)
JWT_SECRET=

# Port the server runs on
PORT=5000

# ── Email (free) for OTP verification + password reset ──
# Use a Gmail address with an "App Password" (free):
#   1. Enable 2-Step Verification on the Google account
#   2. Google Account → Security → App passwords → generate one for "Mail"
#   3. Put the 16-character password below (no spaces)
# If these are left blank, OTP/reset codes are printed to the server console
# instead of emailed (handy for local testing).
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=NOVA <youraddress@gmail.com>
